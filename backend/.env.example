# ========================================
# LegalAI Backend — Environment Variables
# ========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Database Configuration
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&tls=true
DB_NAME=legal_ai

# JWT Secrets (generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
SECRET_KEY=CHANGE_ME_generate_a_strong_random_key
ADMIN_SECRET_KEY=CHANGE_ME_generate_a_strong_random_key
ADMIN_JWT_SECRET=CHANGE_ME_generate_a_strong_random_key

# AI API Keys
GEMINI_API_KEY=your-gemini-api-key-from-aistudio
GROQ_API_KEY=your-groq-api-key-from-console

# Application Settings
DEBUG=False
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Frontend URL (used in verification/reset email links)
FRONTEND_URL=http://localhost:3000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_TLS=True
